# ── Telegram (optional — falls back to console if unset) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Ollama (optional — falls back to template messages if unset) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Audit log signing key (required for HMAC chain — generate any random string) ──
AUDIT_HMAC_SECRET=change-me-in-production

# ── Server ──
PORT=3000
TICK_INTERVAL_SEC=30

# ── Security (optional — disabled by default for development) ──
# Set a secret API key to require `Authorization: Bearer <key>` on all /api/* requests.
# Leave empty to allow unauthenticated access (single-user / hackathon mode).
# AURA_API_KEY=your-secret-key-here

# ── Voice (optional) ──
# Set to 0 to disable voice synthesis (macOS say / Windows PowerShell)
# VOICE_ENABLED=1
# VOICE_NAME=Samantha
